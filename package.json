{
  "name": "pi-graphify",
  "version": "1.0.0",
  "description": "Knowledge-graph-first reasoning for pi coding agents — wraps graphify into automatic agent prompts, reminders, and commands.",
  "keywords": [
    "pi-package",
    "pi",
    "graphify",
    "coding-agent",
    "knowledge-graph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c4iov1/pi-graphify.git"
  },
  "bugs": {
    "url": "https://github.com/c4iov1/pi-graphify/issues"
  },
  "homepage": "https://github.com/c4iov1/pi-graphify#readme",
  "type": "module",
  "files": [
    "extensions",
    "skills",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "evals": "node --test --experimental-strip-types evals/*.test.ts",
    "evals:live": "node --experimental-strip-types evals/run-live.ts",
    "evals:live:dry": "node --experimental-strip-types evals/run-live.ts --dry-run",
    "evals:judge": "node --experimental-strip-types evals/run-judge.ts",
    "evals:judge:dry": "node --experimental-strip-types evals/run-judge.ts --dry-run",
    "evals:report": "node --experimental-strip-types evals/render-report.ts",
    "evals:full": "npm run evals && npm run evals:live && npm run evals:judge && npm run evals:report",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.68.1"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  }
}
